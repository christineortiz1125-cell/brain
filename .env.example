# ── Mobile app (Expo) ──────────────────────────────────────────────
# URL of your running Brain backend. Use your local IP for device testing,
# or your deployed URL for production. Do NOT use localhost on a real device.
EXPO_PUBLIC_BACKEND_URL=http://192.168.1.X:8000

# Supabase — only needed if enabling cloud sync / auth
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Backend (backend/.env) ─────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: port override (default 8000)
# PORT=8000
